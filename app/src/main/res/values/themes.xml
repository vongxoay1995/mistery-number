<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.SortOrder" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Transparent system bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
        <!-- Draw content behind system bars -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <!-- Background -->
        <!-- Allow content in display cutout (notch) area -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>

    <style name="Theme.SortOrder" parent="Base.Theme.SortOrder" />

    <style name="Theme.SortOrder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.SortOrder</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.SortOrder.Main" parent="Theme.SortOrder">
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
